{
  "name": "zenboard",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "npm --workspaces --if-present run test",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "npm --workspaces --if-present run check-types",
    "typecheck": "npm run check-types"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.7.5",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "npm@10.9.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
