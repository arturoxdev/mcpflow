# NeonDB connection string
# Get your connection string from https://console.neon.tech
DATABASE_URL=postgresql://user:password@host/db?sslmode=require&channel_binding=require

# Clerk Authentication (required)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/general
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/general

# Public URL del deploy. Se inyecta en el SKILL.md de la pagina /skill al copiar.
# En local puedes dejarlo vacio: la pagina hace fallback a window.location.origin.
NEXT_PUBLIC_LIVE_URL=https://tu-dominio.example
